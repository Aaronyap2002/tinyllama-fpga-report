\newlabel{lst:dequantize}{{5.5}{42}{\texttt {dequantize<S>} implementation from \texttt {forward.h}. Each element is recovered by multiplying its INT8 value by the corresponding group scale. No pragma directives are applied because the loop has no carried dependencies and no memory port conflicts. The division \texttt {i/GS} is replaced by a bitwise right shift by the compiler since \texttt {GS} is a compile-time power of two}{lstlisting.230}{}}
\newlabel{lst:dequantize@cref}{{[listing][5][5]5.5}{[1][42][]42}{}{}{}}
\@writefile{lol}{\contentsline {lstlisting}{\numberline {5.5}{\ignorespaces \texttt  {dequantize<S>} implementation from \texttt  {forward.h}. Each element is recovered by multiplying its INT8 value by the corresponding group scale. No pragma directives are applied because the loop has no carried dependencies and no memory port conflicts. The division \texttt  {i/GS} is replaced by a bitwise right shift by the compiler since \texttt  {GS} is a compile-time power of two.}}{42}{lstlisting.230}\protected@file@percent }
