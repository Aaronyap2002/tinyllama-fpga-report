\newlabel{lst:quantize}{{5.3}{35}{Group-wise quantisation in \texttt {quantize<S>} from \texttt {forward.h}. The outer loop iterates over groups; the inner scan finds \texttt {wmax} and the second inner loop converts each element. The compile-time constant \texttt {GS} replaces the runtime parameter \texttt {runtime\_gs} so the compiler can evaluate \texttt {S/GS} as a constant expression}{lstlisting.153}{}}
\newlabel{lst:quantize@cref}{{[listing][3][5]5.3}{[1][35][]35}{}{}{}}
\@writefile{lol}{\contentsline {lstlisting}{\numberline {5.3}{\ignorespaces Group-wise quantisation in \texttt  {quantize<S>} from \texttt  {forward.h}. The outer loop iterates over groups; the inner scan finds \texttt  {wmax} and the second inner loop converts each element. The compile-time constant \texttt  {GS} replaces the runtime parameter \texttt  {runtime\_gs} so the compiler can evaluate \texttt  {S/GS} as a constant expression.}}{35}{lstlisting.153}\protected@file@percent }
