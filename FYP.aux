\newlabel{lst:dequantize}{{4.3}{37}{\texttt {dequantize<S>} implementation from \texttt {forward.h}. Each element is recovered by multiplying its INT8 value by the corresponding group scale. No pragma directives are applied because the loop has no carried dependencies and no memory port conflicts. The division \texttt {i/GS} is replaced by a bitwise right shift by the compiler since \texttt {GS} is a compile-time power of two}{lstlisting.152}{}}
\newlabel{lst:dequantize@cref}{{[listing][3][4]4.3}{[1][36][]37}{}{}{}}
\@writefile{lol}{\contentsline {lstlisting}{\numberline {4.3}{\ignorespaces \texttt  {dequantize<S>} implementation from \texttt  {forward.h}. Each element is recovered by multiplying its INT8 value by the corresponding group scale. No pragma directives are applied because the loop has no carried dependencies and no memory port conflicts. The division \texttt  {i/GS} is replaced by a bitwise right shift by the compiler since \texttt  {GS} is a compile-time power of two.}}{37}{lstlisting.152}\protected@file@percent }
