\newlabel{lst:matmul}{{4.4}{42}{Core loop structure of \texttt {matmul<N,D>} from \texttt {forward.h}. The outer row loop is pipelined. The inner loading loops (\texttt {matmul1}, \texttt {matmul2}) and the grouped dot product loops (\texttt {matmul3}, \texttt {matmul4}) execute sequentially within each pipeline iteration. The \texttt {UNROLL} pragmas on \texttt {matmul1} and \texttt {matmul2} are commented out to prevent AXI interface flooding at full scale}{lstlisting.177}{}}
\newlabel{lst:matmul@cref}{{[listing][4][4]4.4}{[1][42][]42}{}{}{}}
\@writefile{lol}{\contentsline {lstlisting}{\numberline {4.4}{\ignorespaces Core loop structure of \texttt  {matmul<N,D>} from \texttt  {forward.h}. The outer row loop is pipelined. The inner loading loops (\texttt  {matmul1}, \texttt  {matmul2}) and the grouped dot product loops (\texttt  {matmul3}, \texttt  {matmul4}) execute sequentially within each pipeline iteration. The \texttt  {UNROLL} pragmas on \texttt  {matmul1} and \texttt  {matmul2} are commented out to prevent AXI interface flooding at full scale.}}{42}{lstlisting.177}\protected@file@percent }
