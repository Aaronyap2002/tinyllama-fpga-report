\newlabel{lst:softmax}{{5.9}{57}{\texttt {softmax<MAXSIZE>} implementation from \texttt {forward.h} (baseline iteration). The \texttt {max} and \texttt {sum} loops carry no \texttt {UNROLL} because of their loop-carried dependencies on \texttt {max\_val} and \texttt {sum} respectively. The \texttt {exp} and \texttt {norm} loops are fully unrolled into 16 parallel datapath lanes. The \texttt {inv\_sum} reciprocal hoists the single division out of the \texttt {norm} loop body}{lstlisting.343}{}}
\newlabel{lst:softmax@cref}{{[listing][9][5]5.9}{[1][57][]57}{}{}{}}
\@writefile{lol}{\contentsline {lstlisting}{\numberline {5.9}{\ignorespaces \texttt  {softmax<MAXSIZE>} implementation from \texttt  {forward.h} (baseline iteration). The \texttt  {max} and \texttt  {sum} loops carry no \texttt  {UNROLL} because of their loop-carried dependencies on \texttt  {max\_val} and \texttt  {sum} respectively. The \texttt  {exp} and \texttt  {norm} loops are fully unrolled into 16 parallel datapath lanes. The \texttt  {inv\_sum} reciprocal hoists the single division out of the \texttt  {norm} loop body.}}{57}{lstlisting.343}\protected@file@percent }
