\contentsline {table}{\numberline {4.55}{\ignorespaces C-simulation output for the baseline float attention kernel (\texttt {attn\_baseline\_top}) at \texttt {pos\,=\,3}, \texttt {loff\,=\,0}. All eight elements of the weighted value accumulation \texttt {xb} match the software reference with zero absolute error.}}{69}{table.caption.504}%
\contentsline {table}{\numberline {4.56}{\ignorespaces Timing summary for \texttt {attn\_baseline\_top} at the \SI {150}{\mega \hertz } (\SI {6.667}{\nano \second }) target clock.}}{70}{table.caption.506}%
\contentsline {table}{\numberline {4.57}{\ignorespaces Top-level latency summary for \texttt {attn\_baseline\_top} at \SI {150}{\mega \hertz }. The minimum corresponds to \texttt {pos\,=\,0} (one attended position) and the maximum to \texttt {pos\,=\,seq\_len\,$-$\,1\,=\,15} (sixteen attended positions).}}{70}{table.caption.507}%
\contentsline {table}{\numberline {4.58}{\ignorespaces Resource utilisation of the baseline float attention block synthesised at prototype scale on the ZCU102. The core-only column excludes the AXI master adapter and S-AXILite control interface.}}{70}{table.caption.508}%
\contentsline {table}{\numberline {4.59}{\ignorespaces Per-pipeline-module latency breakdown of the baseline float attention block at \SI {150}{\mega \hertz }, for one head at maximum context length (\texttt {pos\,=\,15}). The outer \texttt {multihead\_attention} loop over \texttt {n\_heads\,=\,2} runs sequentially, so the per-head cost is incurred twice.}}{71}{table.caption.509}%
\contentsline {table}{\numberline {4.60}{\ignorespaces Comparison of \texttt {xb} outputs from the baseline float attention and the refined per-head INT8 attention for identical inputs at \texttt {pos\,=\,3}. The absolute difference and relative error in each element reflect the quantisation error introduced by the INT8 arithmetic path. Both kernels passed their respective csim runs with zero errors against their own software references.}}{75}{table.caption.543}%
\contentsline {table}{\numberline {4.61}{\ignorespaces Resource utilisation comparison between the baseline float attention and the refined per-head INT8 attention, both synthesised at prototype scale on the ZCU102 at \SI {150}{\mega \hertz }. Core-only figures exclude the AXI master adapter and S-AXILite control interface.}}{76}{table.caption.545}%
\contentsline {table}{\numberline {4.62}{\ignorespaces Per-pipeline-module latency breakdown of the refined per-head INT8 attention block at \SI {150}{\mega \hertz }, for one head at maximum context (\texttt {pos\,=\,256}, \texttt {MAXSIZE\,=\,257}). The outer \texttt {multihead\_attention} loop over \texttt {n\_heads\,=\,2} runs sequentially, giving a worst-case total of approximately 9{,}332 cycles.}}{76}{table.caption.546}%
\contentsline {table}{\numberline {4.63}{\ignorespaces C-simulation \texttt {xb} outputs for all three attention iterations at identical inputs (\texttt {pos\,=\,3}, \texttt {loff\,=\,0}). Iteration~3 outputs are closer to the float baseline than iteration~2, reflecting the higher fidelity of pre-quantised group-scale storage compared to per-position on-the-fly quantisation.}}{79}{table.caption.577}%
\contentsline {table}{\numberline {4.64}{\ignorespaces Resource utilisation across all three attention iterations on the ZCU102 at \SI {150}{\mega \hertz }. Core figures for iterations~1 and~2 exclude the AXI master adapter and S-AXILite control interface. The same exclusions apply to the iteration~3 core column.}}{80}{table.caption.579}%
\contentsline {table}{\numberline {4.65}{\ignorespaces Per-pipeline-module latency breakdown of the iteration~3 INT8-KV attention block at \SI {150}{\mega \hertz }, for one head at \texttt {pos\,=\,15}. The \texttt {sum} stage reflects the unrolled softmax from \cref {subsec:softmax_iter3}.}}{80}{table.caption.580}%
\contentsline {table}{\numberline {4.66}{\ignorespaces C-simulation \texttt {xb} outputs for all four attention iterations at \texttt {pos\,=\,3}, \texttt {loff\,=\,0}. Iteration~4 introduces additional approximation error relative to iteration~3 from the coarse LUT exponential, but all four csim runs passed with zero errors against their respective software references.}}{82}{table.caption.584}%
\contentsline {table}{\numberline {4.67}{\ignorespaces Resource comparison between iteration~3 and iteration~4 attention implementations on the ZCU102. Replacing \texttt {softmax<16>} with \texttt {softmax\_ibert<16>} reduces DSP usage from 194 to 16 and LUT usage from 70{,}514 to 31{,}828 core LUTs. BRAM usage is unchanged at 18 core blocks.}}{83}{table.caption.586}%
\contentsline {table}{\numberline {4.68}{\ignorespaces Per-module latency breakdown for the iteration~4 attention kernel at \SI {150}{\mega \hertz }. The minimum corresponds to \texttt {pos\,=\,0} (one attended position) and the maximum to \texttt {pos\,=\,15} (\texttt {MAX\_SIZE\,=\,16}).}}{83}{table.caption.587}%
\contentsline {table}{\numberline {4.69}{\ignorespaces C-simulation \texttt {xb} outputs at \texttt {pos\,=\,3} for iteration~4 (prototype scale, $\texttt {n\_heads\,=\,2}$) and iteration~5 (full scale, $\texttt {n\_heads\,=\,32}$). The output values differ because the full-scale kernel processes 32 heads at \texttt {head\_size\,=\,64} rather than 2 heads at \texttt {head\_size\,=\,4}, producing a different output range from the same KV cache input pattern.}}{87}{table.caption.660}%
\contentsline {table}{\numberline {4.70}{\ignorespaces Timing summary for \texttt {attn\_update3\_top} at the \SI {150}{\mega \hertz } target clock.}}{87}{table.caption.662}%
\contentsline {table}{\numberline {4.71}{\ignorespaces Top-level latency summary for \texttt {attn\_update3\_top} at \SI {150}{\mega \hertz }. The minimum corresponds to \texttt {pos\,=\,0} (one attended position per head) and the maximum to \texttt {pos\,=\,2047} (full context length).}}{87}{table.caption.663}%
\contentsline {table}{\numberline {4.72}{\ignorespaces Resource utilisation of \texttt {attn\_update3\_top} at full TinyLlama scale on the ZCU102. Core-only figures exclude the three AXI master adapters (\texttt {gmem1}--\texttt {gmem3}, 4\,BRAM, 512\,FF, 580\,LUT each) and the S-AXILite control block (501\,FF, 874\,LUT).}}{88}{table.caption.664}%
\contentsline {table}{\numberline {4.73}{\ignorespaces Per-module latency breakdown for \texttt {attn\_update3\_top} at \SI {150}{\mega \hertz }. Minimum latency corresponds to \texttt {pos\,=\,0} and maximum to \texttt {pos\,=\,2047}.}}{88}{table.caption.665}%
\contentsline {table}{\numberline {4.74}{\ignorespaces C-simulation output for \texttt {ffn\_baseline} with input $\mathbf {x} = [0.1, 0.2, \ldots , 0.8]$ and unit RMSNorm weights. All eight elements agree with the software reference within the INT8 quantisation tolerance.}}{91}{table.caption.669}%
\contentsline {table}{\numberline {4.75}{\ignorespaces Timing summary for \texttt {ffn\_baseline\_top} at the \SI {150}{\mega \hertz } target clock.}}{91}{table.caption.671}%
\contentsline {table}{\numberline {4.76}{\ignorespaces Top-level latency summary for \texttt {ffn\_baseline\_top} at \SI {150}{\mega \hertz }.}}{91}{table.caption.672}%
\contentsline {table}{\numberline {4.77}{\ignorespaces Resource utilisation of \texttt {ffn\_baseline} synthesised at prototype dimensions ($\texttt {dim} = 8$, $\texttt {hidden\_dim} = 32$) on the ZCU102. Core-only figures exclude the two AXI master adapters (\texttt {gmem0\_m\_axi} and \texttt {gmem1\_m\_axi}).}}{92}{table.caption.673}%
\contentsline {table}{\numberline {4.78}{\ignorespaces Per-stage latency breakdown of \texttt {ffn\_baseline\_top} at \SI {150}{\mega \hertz } (prototype dimensions). The gate and up projections share a single \texttt {matmul\_8\_32\_s} instance called sequentially.}}{92}{table.caption.674}%
\contentsline {table}{\numberline {4.79}{\ignorespaces C-simulation output for \texttt {ffn\_update3} (first 8 of 2048 elements). All absolute errors are well within the \num {0.05} tolerance. The small output magnitudes reflect three sequential quantised matrix multiplications with weight scale factors of \num {0.03}--\num {0.05}.}}{95}{table.caption.708}%
\contentsline {table}{\numberline {4.80}{\ignorespaces Timing summary for \texttt {ffn\_update3\_top} at the \SI {150}{\mega \hertz } target clock. The estimated path of \SI {7.456}{\nano \second } plus \SI {1.800}{\nano \second } uncertainty exceeds the \SI {6.667}{\nano \second } budget by \SI {2.589}{\nano \second }.}}{95}{table.caption.710}%
\contentsline {table}{\numberline {4.81}{\ignorespaces Top-level latency summary for \texttt {ffn\_update3\_top} at \SI {150}{\mega \hertz }.}}{95}{table.caption.711}%
\contentsline {table}{\numberline {4.82}{\ignorespaces Resource utilisation of \texttt {ffn\_update3\_top} on the ZCU102 at full TinyLlama scale. Core-only figures exclude the four AXI master adapters (\texttt {gmem0}--\texttt {gmem3}, 4\,BRAM, 512\,FF, 580\,LUT each) and the S-AXILite control block (673\,FF, 1{,}194\,LUT).}}{96}{table.caption.712}%
\contentsline {table}{\numberline {4.83}{\ignorespaces Per-stage latency breakdown of \texttt {ffn\_update3\_top} at \SI {150}{\mega \hertz }. HLS infers one \texttt {matmul\_2048\_5632\_s} instance reused for both the gate ($\mathbf {W}_1$) and up ($\mathbf {W}_3$) projections, so the listed cycles represent two sequential calls through the same module.}}{96}{table.caption.713}%
\contentsline {table}{\numberline {4.84}{\ignorespaces AXI master bundle assignment in the prototype \texttt {forward} kernel (\texttt {forward.cpp}). All weight and KV cache traffic shares a single AXI master port on \texttt {gmem0}.}}{98}{table.caption.716}%
