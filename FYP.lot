\contentsline {table}{\numberline {4.21}{\ignorespaces Latency breakdown of \texttt {matmul} ($N = D = 8$, $GS = 4$) at \SI {150}{\mega \hertz }. Total function latency is 146 cycles (\SI {973}{\nano \second }).}}{40}{table.caption.183}%
\contentsline {table}{\numberline {4.22}{\ignorespaces C-simulation output for \texttt {softmax} with input $[-1.2, 0.5, 1.8, 4.5, -0.3, 2.1, -2.7, 0.9]$, $\texttt {size} = 8$, $\texttt {MAXSIZE} = 16$. All eight elements match the software reference, and the sum of outputs is $1.00000000$.}}{44}{table.caption.220}%
\contentsline {table}{\numberline {4.23}{\ignorespaces Timing summary for \texttt {softmax\_top} at the \SI {150}{\mega \hertz } (\SI {6.667}{\nano \second }) target clock.}}{44}{table.caption.222}%
\contentsline {table}{\numberline {4.24}{\ignorespaces Top-level latency summary for \texttt {softmax\_top} at \SI {150}{\mega \hertz }. The minimum corresponds to $\texttt {size} = 1$ and the maximum to $\texttt {size} = \texttt {MAXSIZE} = 16$.}}{45}{table.caption.223}%
\contentsline {table}{\numberline {4.25}{\ignorespaces Resource utilisation of \texttt {softmax} synthesised at $\texttt {MAXSIZE} = 16$ on the ZCU102 (\texttt {xczu9eg-ffvb1156-2-e}). The core-only column excludes the AXI master adapter and S-AXILite control interface.}}{45}{table.caption.224}%
\contentsline {table}{\numberline {4.26}{\ignorespaces Per-loop latency breakdown of \texttt {softmax} ($\texttt {MAXSIZE} = 16$) at \SI {150}{\mega \hertz }. The \texttt {exp} and \texttt {norm} loops report trip count~1 because \texttt {UNROLL factor=16} on a 16-element loop collapses all iterations into a single parallel pipeline stage.}}{45}{table.caption.225}%
\contentsline {table}{\numberline {4.27}{\ignorespaces Timing summary for \texttt {softmax\_kvint8\_top} at the \SI {150}{\mega \hertz } target clock. The estimated path of \SI {5.084}{\nano \second } plus the \SI {1.800}{\nano \second } uncertainty exceeds the \SI {6.667}{\nano \second } budget by \SI {0.217}{\nano \second }, constituting a timing violation.}}{47}{table.caption.229}%
\contentsline {table}{\numberline {4.28}{\ignorespaces Per-loop latency breakdown of the iteration~3 \texttt {softmax} ($\texttt {MAXSIZE} = 16$) at \SI {150}{\mega \hertz }. The \texttt {sum} loop collapses to a single effective iteration (trip count~1) due to the \texttt {UNROLL factor=16}, but its total latency increases from 97 to 185 cycles compared to iteration~1.}}{48}{table.caption.230}%
\contentsline {table}{\numberline {4.29}{\ignorespaces Resource utilisation comparison between the iteration~1 baseline and the iteration~3 \texttt {softmax} designs, both at $\texttt {MAXSIZE} = 16$ on the \texttt {xczu9eg-ffvb1156-2-e}. Core figures exclude the AXI adapter and S-AXILite control interface.}}{48}{table.caption.231}%
\contentsline {table}{\numberline {4.30}{\ignorespaces C-simulation output for \texttt {softmax\_ibert} with \texttt {logits} $= \{10, -5, 18, 25, -3, 21, -2, 9\}$, \texttt {scale\_factor\,=\,0.2f}, and \texttt {size\,=\,8}. All eight output probabilities match the software reference. The sum of active probabilities is $124$, falling short of $127$ due to integer division in the normalisation step.}}{50}{table.caption.235}%
\contentsline {table}{\numberline {4.31}{\ignorespaces Timing summary for \texttt {softmax\_ibert\_top} at the \SI {150}{\mega \hertz } target clock.}}{51}{table.caption.237}%
\contentsline {table}{\numberline {4.32}{\ignorespaces Top-level latency summary for \texttt {softmax\_ibert\_top} at \SI {150}{\mega \hertz }.}}{51}{table.caption.238}%
\contentsline {table}{\numberline {4.33}{\ignorespaces Resource utilisation of \texttt {softmax\_ibert} synthesised at $\texttt {MAX\_SIZE} = 16$ on the ZCU102.}}{51}{table.caption.239}%
\contentsline {table}{\numberline {4.34}{\ignorespaces Latency breakdown of \texttt {softmax\_ibert} ($\texttt {MAX\_SIZE} = 16$) at \SI {150}{\mega \hertz }. All loops are fully unrolled so HLS reports no per-loop trip count; the breakdown is therefore given at the submodule level. AXI wrapper overhead covers the input and output burst transfers.}}{51}{table.caption.240}%
\contentsline {table}{\numberline {4.35}{\ignorespaces C-simulation output for the baseline float attention kernel (\texttt {attn\_baseline\_top}) at \texttt {pos\,=\,3}, \texttt {loff\,=\,0}. All eight elements of the weighted value accumulation \texttt {xb} match the software reference with zero absolute error.}}{55}{table.caption.270}%
\contentsline {table}{\numberline {4.36}{\ignorespaces Timing summary for \texttt {attn\_baseline\_top} at the \SI {150}{\mega \hertz } (\SI {6.667}{\nano \second }) target clock.}}{55}{table.caption.272}%
\contentsline {table}{\numberline {4.37}{\ignorespaces Top-level latency summary for \texttt {attn\_baseline\_top} at \SI {150}{\mega \hertz }. The minimum corresponds to \texttt {pos\,=\,0} (one attended position) and the maximum to \texttt {pos\,=\,seq\_len\,$-$\,1\,=\,15} (sixteen attended positions).}}{56}{table.caption.273}%
\contentsline {table}{\numberline {4.38}{\ignorespaces Resource utilisation of the baseline float attention block synthesised at prototype scale on the ZCU102 (\texttt {xczu9eg-ffvb1156-2-e}). The core-only column excludes the AXI master adapter and S-AXILite control interface.}}{56}{table.caption.274}%
\contentsline {table}{\numberline {4.39}{\ignorespaces Per-pipeline-module latency breakdown of the baseline float attention block at \SI {150}{\mega \hertz }, for one head at maximum context length (\texttt {pos\,=\,15}). The outer \texttt {multihead\_attention} loop over \texttt {n\_heads\,=\,2} runs sequentially, so the per-head cost is incurred twice.}}{56}{table.caption.275}%
\contentsline {table}{\numberline {4.40}{\ignorespaces Comparison of \texttt {xb} outputs from the baseline float attention and the refined per-head INT8 attention for identical inputs at \texttt {pos\,=\,3}. The absolute difference and relative error in each element reflect the quantisation error introduced by the INT8 arithmetic path. Both kernels passed their respective csim runs with zero errors against their own software references.}}{60}{table.caption.309}%
\contentsline {table}{\numberline {4.41}{\ignorespaces Resource utilisation comparison between the baseline float attention and the refined per-head INT8 attention, both synthesised at prototype scale on the \texttt {xczu9eg-ffvb1156-2-e} at \SI {150}{\mega \hertz }. Core-only figures exclude the AXI master adapter and S-AXILite control interface.}}{61}{table.caption.311}%
\contentsline {table}{\numberline {4.42}{\ignorespaces Per-pipeline-module latency breakdown of the refined per-head INT8 attention block at \SI {150}{\mega \hertz }, for one head at maximum context (\texttt {pos\,=\,256}, \texttt {MAXSIZE\,=\,257}). The outer \texttt {multihead\_attention} loop over \texttt {n\_heads\,=\,2} runs sequentially, giving a worst-case total of approximately 9{,}332 cycles.}}{61}{table.caption.312}%
\contentsline {table}{\numberline {4.43}{\ignorespaces C-simulation \texttt {xb} outputs for all three attention iterations at identical inputs (\texttt {pos\,=\,3}, \texttt {loff\,=\,0}). Iteration~3 outputs are substantially closer to the float baseline than iteration~2, reflecting the higher fidelity of pre-quantised group-scale storage compared to per-position on-the-fly quantisation.}}{64}{table.caption.343}%
\contentsline {table}{\numberline {4.44}{\ignorespaces Resource utilisation across all three attention iterations on the \texttt {xczu9eg-ffvb1156-2-e} at \SI {150}{\mega \hertz }. Core figures for iterations~1 and~2 exclude the AXI master adapter and S-AXILite control interface. The same exclusions apply to the iteration~3 core column.}}{65}{table.caption.345}%
\contentsline {table}{\numberline {4.45}{\ignorespaces Per-pipeline-module latency breakdown of the iteration~3 INT8-KV attention block at \SI {150}{\mega \hertz }, for one head at \texttt {pos\,=\,15}. The \texttt {sum} stage reflects the unrolled softmax from \cref {subsec:softmax_iter3}.}}{66}{table.caption.346}%
\contentsline {table}{\numberline {4.46}{\ignorespaces C-simulation \texttt {xb} outputs for all four attention iterations at \texttt {pos\,=\,3}, \texttt {loff\,=\,0}. Iteration~4 introduces additional approximation error relative to iteration~3 from the coarse LUT exponential, but all four csim runs passed with zero errors against their respective software references.}}{68}{table.caption.350}%
\contentsline {table}{\numberline {4.47}{\ignorespaces Resource comparison between iteration~3 and iteration~4 attention implementations on the ZCU102. Replacing \texttt {softmax<16>} with \texttt {softmax\_ibert<16>} reduces DSP usage from 194 to 16 and LUT usage from 70{,}514 to 31{,}828 core LUTs. BRAM usage is unchanged at 18 core blocks.}}{69}{table.caption.352}%
\contentsline {table}{\numberline {4.48}{\ignorespaces Per-module latency breakdown for the iteration~4 attention kernel at \SI {150}{\mega \hertz }. The minimum corresponds to \texttt {pos\,=\,0} (one attended position) and the maximum to \texttt {pos\,=\,15} (\texttt {MAX\_SIZE\,=\,16}).}}{69}{table.caption.353}%
\contentsline {table}{\numberline {4.49}{\ignorespaces C-simulation output for \texttt {ffn\_baseline} with input $\mathbf {x} = [0.1, 0.2, \ldots , 0.8]$ and unit RMSNorm weights. All eight elements agree with the software reference within the INT8 quantisation tolerance.}}{71}{table.caption.357}%
\contentsline {table}{\numberline {4.50}{\ignorespaces Timing summary for \texttt {ffn\_baseline\_top} at the \SI {150}{\mega \hertz } target clock.}}{72}{table.caption.359}%
\contentsline {table}{\numberline {4.51}{\ignorespaces Top-level latency summary for \texttt {ffn\_baseline\_top} at \SI {150}{\mega \hertz }.}}{72}{table.caption.360}%
\contentsline {table}{\numberline {4.52}{\ignorespaces Resource utilisation of \texttt {ffn\_baseline} synthesised at prototype dimensions ($\texttt {dim} = 8$, $\texttt {hidden\_dim} = 32$) on the ZCU102. Core-only figures exclude the two AXI master adapters (\texttt {gmem0\_m\_axi} and \texttt {gmem1\_m\_axi}).}}{72}{table.caption.361}%
\contentsline {table}{\numberline {4.53}{\ignorespaces Per-stage latency breakdown of \texttt {ffn\_baseline\_top} at \SI {150}{\mega \hertz } (prototype dimensions). Total function latency is 1{,}487 cycles (\SI {9.914}{\micro \second }). The gate and up projections share a single \texttt {matmul\_8\_32\_s} instance called sequentially.}}{72}{table.caption.362}%
\contentsline {table}{\numberline {4.54}{\ignorespaces AXI master bundle assignment in the prototype \texttt {forward} kernel (\texttt {forward.cpp}). All weight and KV cache traffic shares a single AXI master port on \texttt {gmem0}.}}{74}{table.caption.365}%
